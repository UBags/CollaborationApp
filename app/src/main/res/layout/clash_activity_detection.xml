<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".clash.ClashDetectionActivity">

    <TextView
        android:id="@+id/clashDetectionTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/clash_detection_title"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginTop="16dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Horizontal LinearLayout for sticky column headers -->
    <LinearLayout
        android:id="@+id/columnHeaderLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="4"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@+id/clashDetectionTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:background="#E0E0E0"
        android:paddingTop="4dp"
        android:paddingBottom="4dp">

        <!-- Space to align with time labels in ClashDetectionView -->
        <Space
            android:layout_width="48dp"
            android:layout_height="wrap_content" />

        <!-- These TextViews will act as your sticky headers -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/clash_details_format_lecture_short"
            android:gravity="center"
            android:textStyle="bold"
            android:textSize="14sp"
            android:paddingVertical="4dp"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/clash_details_format_personal_short"
            android:gravity="center"
            android:textStyle="bold"
            android:textSize="14sp"
            android:paddingVertical="4dp"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/clash_details_format_engagement_short"
            android:gravity="center"
            android:textStyle="bold"
            android:textSize="14sp"
            android:paddingVertical="4dp"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/clash_details_format_exam_short"
            android:gravity="center"
            android:textStyle="bold"
            android:textSize="14sp"
            android:paddingVertical="4dp"/>
    </LinearLayout>

    <!-- ScrollView for the ClashDetectionView -->
    <ScrollView
        android:id="@+id/clashDetectionScrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="0dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="8dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/columnHeaderLayout"
        app:layout_constraintBottom_toTopOf="@+id/daySelectionLayout">

        <com.costheta.cortexa.clash.ClashDetectionView
            android:id="@+id/clashDetectionView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />
    </ScrollView>

    <!-- Day Selection Buttons -->
    <LinearLayout
        android:id="@+id/daySelectionLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:padding="8dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <Button
            android:id="@+id/btnDay1"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_margin="2dp"
            android:text="1"
            android:textStyle="bold"
            android:textSize="14sp"
            style="@style/ScheduleDayButton" />

        <Button
            android:id="@+id/btnDay2"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_margin="2dp"
            android:text="2"
            android:textStyle="bold"
            android:textSize="14sp"
            style="@style/ScheduleDayButton" />

        <Button
            android:id="@+id/btnDay3"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_margin="2dp"
            android:text="3"
            android:textStyle="bold"
            android:textSize="14sp"
            style="@style/ScheduleDayButton" />

        <Button
            android:id="@+id/btnDay4"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_margin="2dp"
            android:text="4"
            android:textStyle="bold"
            android:textSize="14sp"
            style="@style/ScheduleDayButton" />

        <Button
            android:id="@+id/btnDay5"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_margin="2dp"
            android:text="5"
            android:textStyle="bold"
            android:textSize="14sp"
            style="@style/ScheduleDayButton" />

        <Button
            android:id="@+id/btnDay6"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_margin="2dp"
            android:text="6"
            android:textStyle="bold"
            android:textSize="14sp"
            style="@style/ScheduleDayButton" />

        <Button
            android:id="@+id/btnDay7"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_margin="2dp"
            android:text="7"
            android:textStyle="bold"
            android:textSize="14sp"
            style="@style/ScheduleDayButton" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
