<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginTop="2dp"
    android:layout_marginBottom="2dp"
    android:background="@drawable/rounded_corners">

    <View
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="@android:color/darker_gray"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="6dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/subtasks_label"
        android:textSize="16sp"
        android:textStyle="bold"
        android:gravity="center"
        android:background="@drawable/rounded_dark_blue_background"
        android:padding="4dp"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="6dp"/>

    <!-- Input for adding new subtasks by sentence -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.MyApp.TextInputLayout.Rounded"
        android:layout_height="wrap_content"
        android:layout_marginBottom="2dp"
        android:hint="@string/subtask_input_hint">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/editTextAddSubtask"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textMultiLine"
            android:textSize="11sp"
            android:maxLines="2"
            android:gravity="top"
            android:autofillHints="text" />
    </com.google.android.material.textfield.TextInputLayout>

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="2dp"
        android:scrollbarThumbHorizontal="@null"
        android:scrollbarSize="0dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonAddSubtask"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/add_subtask_button_text"
                android:textSize="11sp"
                app:icon="@drawable/ic_add"
                app:iconTint="@null"
                app:iconSize="24dp"
                style="@style/Widget.MaterialComponents.Button.TextButton.Icon"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonCopySubtasks"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/copy_subtasks_button_text"
                android:textSize="11sp"
                app:icon="@drawable/ic_copy"
                app:iconTint="@null"
                app:iconSize="24dp"
                android:layout_marginStart="8dp"
                style="@style/Widget.MaterialComponents.Button.TextButton.Icon"/>

        </LinearLayout>
    </HorizontalScrollView>


    <!-- RecyclerView to display the list of subtasks -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewSubtasks"
        android:layout_width="match_parent"
        android:layout_height="250dp"
        android:background="#DDDEEE"
        android:nestedScrollingEnabled="true"
        android:paddingStart="2dp"
        android:paddingTop="2dp"
        android:paddingEnd="4dp"
        android:paddingBottom="4dp"
        app:cardCornerRadius="8dp"
        app:cardElevation="4dp"
        tools:itemCount="5"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="2dp"
        android:visibility="gone"
        tools:listitem="@layout/subtask_item" />

    <TextView
        android:id="@+id/noSubtasksFoundTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/no_subtasks_found"
        android:textSize="12sp"
        android:gravity="center_horizontal"
        android:visibility="visible"
        android:layout_marginTop="2dp"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="4dp"
        app:layout_constraintTop_toBottomOf="@id/recyclerViewSubtasks"
        android:background="@android:color/darker_gray" />

</LinearLayout>
