<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="8dp"
    tools:context=".engagement.AddEngagementActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/addEngagementTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/add_engagement_title"
            android:textSize="14sp"
            android:textStyle="bold"
            android:gravity="center_horizontal"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:textColor="#FFFFFF"
            android:background="@drawable/rounded_dark_green_background"/>

        <!-- Engagement Name -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.MyApp.TextInputLayout.Rounded"
            android:layout_marginBottom="2dp">
            <AutoCompleteTextView
                android:id="@+id/engagementAutoCompleteNameEditText"
                android:hint="@string/engagement_name_hint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:autofillHints="name"
                android:completionThreshold="1"
                android:textSize="11sp"
                android:layout_marginTop="0dp"
                android:layout_marginBottom="0dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp"
                android:paddingStart="16dp"
                android:paddingEnd="8dp"
/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Notes (Optional) -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.MyApp.TextInputLayout.Rounded"
            android:layout_marginBottom="2dp"
            app:startIconDrawable="@drawable/ic_notes"
            app:startIconTint="@null">
            <AutoCompleteTextView
                android:id="@+id/notesAutoCompleteEditText"
                android:hint="@string/notes_hint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textMultiLine|textCapWords"
                android:minLines="3"
                android:gravity="top"
                android:autofillHints="text"
                android:textSize="11sp"
                android:layout_marginTop="0dp"
                android:layout_marginBottom="0dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp"
                android:paddingStart="16dp"
                android:paddingEnd="8dp"
                android:completionThreshold="1" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Day Selection Type Radio Group -->
        <TextView
            android:id="@+id/daySelectionTypeLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/day_selection_type_label"
            android:textStyle="bold"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="4dp" />

        <RadioGroup
            android:id="@+id/daySelectionRadioGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:checkedButton="@+id/radioSelectDays"
            android:layout_marginBottom="4dp">

            <RadioButton
                android:id="@+id/radioSelectDays"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="11sp"
                android:text="@string/radio_select_days"
                android:layout_marginEnd="16dp"/>

            <RadioButton
                android:id="@+id/radioRecur"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="11sp"
                android:text="@string/radio_recur_days"/>
        </RadioGroup>

        <!-- Section for selecting multiple days (initially visible) -->
        <LinearLayout
            android:id="@+id/layoutSelectDays"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="4dp"
            android:layout_gravity="center_horizontal">

            <TextView
                android:id="@+id/dayOfWeekLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/day_of_week_label"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>

            <GridLayout
                android:id="@+id/daysCheckboxGrid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="3"
                android:rowCount="3"
                android:useDefaultMargins="true">
                <!-- Checkboxes will be added programmatically -->
            </GridLayout>
        </LinearLayout>

        <!-- Section for recurrence (initially hidden) -->
        <LinearLayout
            android:id="@+id/layoutRecurDays"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp"
            android:visibility="gone"
            android:layout_marginBottom="4dp"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="4dp"
                android:gravity="end">

                <TextView
                    android:id="@+id/recurrenceLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/recurrence_interval_label"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginEnd="4dp"
                    android:layout_gravity="center"/>

                <NumberPicker
                    android:id="@+id/recurrenceNumberPicker"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_gravity="center"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="days"
                    android:layout_marginStart="8dp"
                    android:layout_gravity="center"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Validity Start Date and End Date side-by-side -->
        <LinearLayout
            android:id="@+id/validityDatesLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="4dp">

            <!-- Validity Start Date -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.MyApp.TextInputLayout.Rounded"
                android:layout_weight="1"
                android:layout_marginTop="0dp"
                android:layout_marginEnd="2dp"
                android:layout_marginBottom="0dp"
                android:minHeight="0dp"
                android:hint="@string/engagement_start_date_hint"
                app:startIconDrawable="@drawable/ic_calendar"
                app:startIconTint="@null">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/engagementStartDateEditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:focusable="false"
                    android:clickable="true"
                    android:inputType="none"
                    android:autofillHints="date"
                    android:textSize="11sp"
                    android:minHeight="0dp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Validity End Date -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.MyApp.TextInputLayout.Rounded"
                android:layout_weight="1"
                android:layout_marginTop="0dp"
                android:layout_marginEnd="2dp"
                android:layout_marginBottom="0dp"
                android:minHeight="0dp"

                android:hint="@string/engagement_end_date_hint"
                app:startIconDrawable="@drawable/ic_calendar"
                app:startIconTint="@null">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/engagementEndDateEditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:focusable="false"
                    android:clickable="true"
                    android:inputType="none"
                    android:autofillHints="date"
                    android:textSize="11sp"
                    android:minHeight="0dp" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <!-- Start Time and Duration side-by-side -->
        <LinearLayout
            android:id="@+id/timeAndDurationLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:baselineAligned="false"
            android:orientation="horizontal"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="4dp">

            <!-- Start Time -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.MyApp.TextInputLayout.Rounded"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:hint="@string/start_time_hint"
                app:startIconDrawable="@drawable/ic_time"
                app:startIconTint="@null">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/startTimeEditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:focusable="false"
                    android:clickable="true"
                    android:inputType="none"
                    android:autofillHints="time"
                    android:textSize="11sp"
                    android:minHeight="0dp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Duration -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.MyApp.TextInputLayout.Rounded"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:hint="@string/duration_hint">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/durationEditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:focusable="false"
                    android:clickable="true"
                    android:inputType="none"
                    android:autofillHints="no"
                    android:textSize="11sp"
                    android:minHeight="0dp" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <!-- NEW: Timezone Display Layout -->
        <LinearLayout
            android:id="@+id/timezoneInfoLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginBottom="2dp"
            android:layout_marginTop="2dp">

            <TextView
                android:id="@+id/currentTimezoneTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:textSize="11sp"
                android:textAppearance="?attr/textAppearanceCaption"
                tools:text="Time: 08:00 in current timezone: America/New_York"
                tools:visibility="visible"/>

            <TextView
                android:id="@+id/originalTimezoneTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textAppearance="?attr/textAppearanceCaption"
                tools:text="Time: 17:30 in original timezone: Asia/Kolkata"
                tools:visibility="gone"/>
        </LinearLayout>

        <!-- NEW: Notification Times Layout -->
        <LinearLayout
            android:id="@+id/notificationTimesLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:baselineAligned="false"
            android:orientation="horizontal"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="4dp"
            android:gravity="center_vertical">

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.MyApp.TextInputLayout.Rounded"
                android:layout_weight="1"
                android:hint="@string/notification1_hint"
                android:layout_marginEnd="4dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/notification1EditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:focusable="false"
                    android:clickable="true"
                    android:inputType="none"
                    android:autofillHints="no"
                    android:textSize="11sp"
                    android:minHeight="0dp" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.MyApp.TextInputLayout.Rounded"
                android:layout_weight="1"
                android:hint="@string/notification2_hint"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/notification2EditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:focusable="false"
                    android:clickable="true"
                    android:inputType="none"
                    android:autofillHints="no"
                    android:textSize="11sp"
                    android:minHeight="0dp"  />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.MyApp.TextInputLayout.Rounded"
                android:layout_weight="1"
                android:hint="@string/notification3_hint"
                android:layout_marginStart="4dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/notification3EditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:focusable="false"
                    android:clickable="true"
                    android:inputType="none"
                    android:autofillHints="no"
                    android:textSize="11sp"
                    android:minHeight="0dp" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <!-- NEW: Include the location picker view here -->
        <com.costheta.cortexa.util.location.LocationPickerView
            android:id="@+id/engagementLocationPickerView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="4dp"/>

        <!-- Silence Notifications Checkbox for ad-hoc engagement -->
        <CheckBox
            android:id="@+id/silenceNotificationsCheckbox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/silence_notifications_label"
            android:textSize="11sp"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="4dp" />

        <!-- NEW: Include the attachment layout here -->
        <include
            android:id="@+id/attachmentLayout"
            layout="@layout/attachment_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="4dp" />

        <!-- NEW: Include the subtasks layout here -->
        <include layout="@layout/subtasks_layout"
            android:id="@+id/subtasksLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp" />

        <!-- Save Button -->
        <Button
            android:id="@+id/saveEngagementButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/save_engagement_button_text" />

    </LinearLayout>
</ScrollView>
