<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ScheduleActivity"
    android:background="@drawable/rounded_corners">

    <TextView
        android:id="@+id/scheduleViewTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/schedule_view_title"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginTop="16dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:background="@drawable/rounded_corners"/>

    <!-- NEW: LinearLayout for sticky column headers -->
    <LinearLayout
        android:id="@+id/columnHeadersLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="8dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/scheduleViewTitle"
        android:background="@drawable/rounded_corners">

        <!-- Space to align with time labels in ScheduleView -->
        <Space
            android:layout_width="0dp"
            android:layout_weight="3"
            android:layout_height="match_parent" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="4"
            android:text="@string/schedule_column_lecture"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:gravity="center"
            android:background="@drawable/rounded_dark_blue_background"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:layout_marginStart="2dp"
            android:layout_marginEnd="2dp"
            tools:ignore="SmallSp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="4"
            android:text="@string/schedule_column_personal"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:gravity="center"
            android:background="@drawable/rounded_dark_blue_background"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:layout_marginStart="2dp"
            android:layout_marginEnd="2dp"
            tools:ignore="SmallSp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="4"
            android:text="@string/schedule_column_engagement"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:gravity="center"
            android:background="@drawable/rounded_dark_blue_background"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:layout_marginStart="2dp"
            android:layout_marginEnd="2dp"
            tools:ignore="SmallSp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="4"
            android:text="@string/schedule_column_action"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:gravity="center"
            android:background="@drawable/rounded_dark_blue_background"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:layout_marginStart="2dp"
            android:layout_marginEnd="2dp"
            tools:ignore="SmallSp" />
    </LinearLayout>


    <ScrollView
        android:id="@+id/scheduleScrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        app:layout_constraintBottom_toTopOf="@+id/dayButtonsLayout"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/columnHeadersLayout">

        <com.costheta.cortexa.ScheduleView
            android:id="@+id/scheduleView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />
    </ScrollView>

    <LinearLayout
        android:id="@+id/dayButtonsLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/scheduleScrollView">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/goLeft"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:textSize="12sp"
            android:textStyle="bold"
            style="@style/ScheduleDayButton"
            android:layout_margin="1dp"
            android:padding="0dp"
            app:icon="@drawable/ic_go_left"
            app:iconGravity="start" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/schedule_btnDay1"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="2"
            android:textSize="12sp"
            android:textStyle="bold"
            style="@style/ScheduleDayButton"
            android:layout_margin="1dp"
            android:padding="0dp"
            tools:text="Mon\n15" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/schedule_btnDay2"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="2"
            android:textSize="12sp"
            android:textStyle="bold"
            style="@style/ScheduleDayButton"
            android:layout_margin="1dp"
            android:padding="0dp"
            tools:text="Tue\n16" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/schedule_btnDay3"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="2"
            android:textSize="12sp"
            android:textStyle="bold"
            style="@style/ScheduleDayButton"
            android:layout_margin="1dp"
            android:padding="0dp"
            tools:text="Wed\n17" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/schedule_btnDay4"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="2"
            android:textSize="12sp"
            android:textStyle="bold"
            style="@style/ScheduleDayButton"
            android:layout_margin="1dp"
            android:padding="0dp"
            tools:text="Thu\n18" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/schedule_btnDay5"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="2"
            android:textSize="12sp"
            android:textStyle="bold"
            style="@style/ScheduleDayButton"
            android:layout_margin="1dp"
            android:padding="0dp"
            tools:text="Fri\n19" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/schedule_btnDay6"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="2"
            android:textSize="12sp"
            android:textStyle="bold"
            style="@style/ScheduleDayButton"
            android:layout_margin="1dp"
            android:padding="0dp"
            tools:text="Sat\n20" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/schedule_btnDay7"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="2"
            android:textSize="12sp"
            android:textStyle="bold"
            style="@style/ScheduleDayButton"
            android:layout_margin="1dp"
            android:padding="0dp"
            tools:text="Sun\n21" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/goRight"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:textSize="12sp"
            android:textStyle="bold"
            style="@style/ScheduleDayButton"
            android:layout_margin="1dp"
            app:icon="@drawable/ic_go_right"
            app:iconGravity="end" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
