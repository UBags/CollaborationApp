<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/rounded_corners"
    >

    <View
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="@android:color/darker_gray"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="6dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/attachment_string_attachments_label"
        android:textSize="16sp"
        android:textStyle="bold"
        android:gravity="center"
        android:background="@drawable/rounded_dark_blue_background"
        android:padding="4dp"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="6dp"/>

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="2dp"
        android:scrollbarThumbHorizontal="@null"
        android:scrollbarSize="0dp">
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonPickFile"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:text="@string/attachment_string_pick_file_button_text"
                app:icon="@drawable/ic_attach_file"
                app:iconTint="@null"
                app:iconSize="24dp"
                style="@style/Widget.MaterialComponents.Button.TextButton.Icon"
                android:layout_marginEnd="8dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonTakePhotoVideo"
                style="@style/Widget.MaterialComponents.Button.TextButton.Icon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:layout_marginEnd="2dp"
                android:text="@string/attachment_string_take_photo_video_button_text"
                app:icon="@drawable/ic_camera"
                app:iconTint="@null"
                app:iconSize="24dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonRecordAudio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:text="@string/attachment_string_record_audio_button_text"
                app:icon="@drawable/ic_mic"
                app:iconTint="@null"
                app:iconSize="24dp"
                style="@style/Widget.MaterialComponents.Button.TextButton.Icon"
                android:layout_marginEnd="2dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonAddHyperlink"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:text="@string/attachment_string_add_hyperlink_button_text"
                app:icon="@drawable/ic_link"
                app:iconTint="@null"
                app:iconSize="24dp"
                style="@style/Widget.MaterialComponents.Button.TextButton.Icon"
                android:layout_marginEnd="8dp"/>

            <!-- ADDED: New button for Copy Attachments -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonCopyAttachments"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:text="@string/attachment_string_copy_attachments_button_text"
                app:icon="@drawable/ic_copy"
                app:iconTint="@null"
                app:iconSize="24dp"
                style="@style/Widget.MaterialComponents.Button.TextButton.Icon"/>

        </LinearLayout>
    </HorizontalScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="2dp">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerViewAttachments"
            android:layout_width="match_parent"
            android:layout_height="250dp"
            android:background="#DDDEEE"
            android:nestedScrollingEnabled="true"
            android:paddingStart="4dp"
            android:paddingTop="2dp"
            android:paddingEnd="4dp"
            android:paddingBottom="2dp"
            app:cardCornerRadius="8dp"
            tools:itemCount="5"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="2dp"
            android:visibility="gone"
            tools:listitem="@layout/attachment_item"/>

        <TextView
            android:id="@+id/noAttachmentsFoundTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/attachment_string_no_attachments_found"
            android:gravity="center_horizontal"
            android:visibility="visible"
            android:layout_marginTop="2dp"/>

    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/buttonShareAttachments"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/attachment_string_share_with_button_text"
        android:textSize="11sp"
        android:layout_marginBottom="2dp"
        app:icon="@drawable/ic_share"
        app:iconTint="@null"
        app:iconSize="24dp"
        style="?attr/materialButtonOutlinedStyle"
        android:visibility="gone" />

    <View
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="4dp"
        app:layout_constraintTop_toBottomOf="@id/buttonShareAttachments"
        android:background="@android:color/darker_gray" />

</LinearLayout>