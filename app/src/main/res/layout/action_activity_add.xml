<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="8dp"
    tools:context=".action.AddActionActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/addActionTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/add_action_title"
            android:textSize="14sp"
            android:textStyle="bold"
            android:gravity="center_horizontal"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:textColor="#FFFFFF"
            android:background="@drawable/rounded_dark_green_background"/>

        <!-- Action Name -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/actionNameInputLayout"
            app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.MyApp.TextInputLayout.Rounded"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="2dp">
            <!-- CHANGED: From TextInputEditText to AutoCompleteTextView -->
            <AutoCompleteTextView
                android:id="@+id/actionNameEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textCapWords"
                android:autofillHints="name"
                android:completionThreshold="1"
                android:textSize="11sp"
                android:layout_marginTop="0dp"
                android:layout_marginBottom="0dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp"
                android:paddingStart="16dp"
                android:paddingEnd="8dp"
                android:hint="@string/action_name_hint"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Description -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.MyApp.TextInputLayout.Rounded"
            android:layout_marginBottom="2dp"
            app:startIconDrawable="@drawable/ic_notes"
            app:startIconTint="@null">

            <!-- CHANGED: From TextInputEditText to AutoCompleteTextView -->
            <AutoCompleteTextView
                android:id="@+id/descriptionEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textCapSentences|textMultiLine"
                android:minLines="2"
                android:completionThreshold="1"
                android:textSize="11sp"
                android:layout_marginTop="0dp"
                android:layout_marginBottom="0dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp"
                android:paddingStart="16dp"
                android:paddingEnd="8dp"
                android:gravity="top"
                android:hint="@string/action_description_hint"
                android:autofillHints="text" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Start Date and Start Time in a horizontal LinearLayout -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:baselineAligned="false"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <!-- Start Date -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp"
                app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.MyApp.TextInputLayout.Rounded"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginTop="0dp"
                android:layout_marginEnd="2dp"
                android:layout_marginBottom="0dp"
                android:minHeight="0dp"
                app:startIconDrawable="@drawable/ic_calendar"
                app:startIconTint="@null">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/startDateEditText"
                    android:hint="@string/action_start_date_hint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:focusable="false"
                    android:clickable="true"
                    android:inputType="none"
                    android:autofillHints="date"
                    android:textSize="11sp"
                    android:minHeight="0dp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Start Time -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp"
                app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.MyApp.TextInputLayout.Rounded"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginTop="0dp"
                android:layout_marginEnd="2dp"
                android:layout_marginBottom="0dp"
                android:minHeight="0dp"
                android:hint="@string/action_start_time_hint"
                app:startIconDrawable="@drawable/ic_time"
                app:startIconTint="@null">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/startTimeEditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:focusable="false"
                    android:clickable="true"
                    android:inputType="none"
                    android:autofillHints="time"
                    android:textSize="11sp"
                    android:minHeight="0dp" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <!-- End Date and End Time in a horizontal LinearLayout -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:baselineAligned="false"
            android:orientation="horizontal"
            android:layout_marginBottom="4dp">

            <!-- End Date -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.MyApp.TextInputLayout.Rounded"
                android:layout_weight="1"
                android:layout_marginTop="0dp"
                android:layout_marginEnd="2dp"
                android:layout_marginBottom="0dp"
                android:minHeight="0dp"
                android:hint="@string/action_end_date_hint"
                app:startIconDrawable="@drawable/ic_calendar"
                app:startIconTint="@null">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/endDateEditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:focusable="false"
                    android:clickable="true"
                    android:inputType="none"
                    android:autofillHints="date"
                    android:textSize="11sp"
                    android:minHeight="0dp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- End Time -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.MyApp.TextInputLayout.Rounded"
                android:layout_weight="1"
                android:layout_marginTop="0dp"
                android:layout_marginEnd="2dp"
                android:layout_marginBottom="0dp"
                android:minHeight="0dp"
                android:hint="@string/action_end_time_hint"
                app:startIconDrawable="@drawable/ic_time"
                app:startIconTint="@null">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/endTimeEditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:focusable="false"
                    android:clickable="true"
                    android:inputType="none"
                    android:autofillHints="time"
                    android:textSize="11sp"
                    android:minHeight="0dp" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <!-- TIMEZONE CHANGE: Timezone Display Layout -->
        <LinearLayout
            android:id="@+id/timezoneInfoLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginBottom="4dp"
            android:visibility="gone"
            tools:visibility="visible">

            <TextView
                android:id="@+id/currentTimezoneTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:textSize="11sp"
                android:textAppearance="?attr/textAppearanceCaption"
                tools:text="End Time: 08:00 (07-Aug-2025) in current timezone: America/New_York"
                tools:visibility="visible"/>

            <TextView
                android:id="@+id/originalTimezoneTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textAppearance="?attr/textAppearanceCaption"
                tools:text="End Time: 17:30 (07-Aug-2025) in original timezone: Asia/Kolkata"/>
        </LinearLayout>

        <!-- Notification 1, 2 and 3 in a horizontal LinearLayout -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:baselineAligned="false"
            android:orientation="horizontal"
            android:layout_marginBottom="4dp">

            <!-- Notification 1 (Minutes before start) -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.MyApp.TextInputLayout.Rounded"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:hint="@string/action_notification1_hint"
                app:startIconDrawable="@drawable/ic_time"
                app:startIconTint="@null">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/notificationMinutes1EditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:focusable="false"
                    android:clickable="true"
                    android:inputType="none"
                    android:autofillHints="number"
                    android:textSize="11sp"
                    android:layout_marginTop="0dp"
                    android:layout_marginBottom="0dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="8dp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Notification 2 (Minutes before start) -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.MyApp.TextInputLayout.Rounded"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:hint="@string/action_notification2_hint"
                app:startIconDrawable="@drawable/ic_time"
                app:startIconTint="@null">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/notificationMinutes2EditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:focusable="false"
                    android:clickable="true"
                    android:inputType="none"
                    android:autofillHints="number"
                    android:textSize="11sp"
                    android:layout_marginTop="0dp"
                    android:layout_marginBottom="0dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="8dp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- NEW: Notification 3 (Minutes before start) -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.MyApp.TextInputLayout.Rounded"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:hint="@string/action_notification3_hint"
                app:startIconDrawable="@drawable/ic_time"
                app:startIconTint="@null">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/notificationMinutes3EditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:focusable="false"
                    android:clickable="true"
                    android:inputType="none"
                    android:autofillHints="number"
                    android:textSize="11sp"
                    android:layout_marginTop="0dp"
                    android:layout_marginBottom="0dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="8dp"/>
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <!-- NEW: Location Picker View -->
        <com.costheta.cortexa.util.location.LocationPickerView
            android:id="@+id/actionLocationPickerView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="2dp" />

        <!-- NEW: Done Checkbox -->
        <CheckBox
            android:id="@+id/doneCheckbox"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/action_done"
            android:textSize="11sp"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="4dp"/>

        <!-- Silence Notifications Checkbox -->
        <CheckBox
            android:id="@+id/silenceNotificationsCheckbox"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/action_silence_notifications"
            android:textSize="11sp"
            android:layout_marginBottom="4dp"/>

        <!-- Include the attachment layout here -->
        <include
            android:id="@+id/attachmentLayout"
            layout="@layout/attachment_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="4dp" />

        <!-- Include the subtasks layout here -->
        <include layout="@layout/subtasks_layout"
            android:id="@+id/subtasksLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="4dp" />

        <!-- Save Button -->
        <Button
            android:id="@+id/saveActionButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/save_action_button_text" />

    </LinearLayout>
</ScrollView>
